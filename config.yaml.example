# LitRecombine Configuration
# Copy this file to config.yaml and fill in your DeepSeek API key.

# DeepSeek API
deepseek:
  api_key: "YOUR_DEEPSEEK_API_KEY"
  base_url: "https://api.deepseek.com"
  model: "deepseek-chat"
  max_tokens: 4096
  temperature: 0.2  # Low temperature for deterministic extraction

# Paths (relative to project root)
paths:
  projects_dir: "projects"
  module_pool_dir: "module_pool"

# Extraction settings
extraction:
  # Modules to extract from each paper
  modules:
    - id: "core_method"
      label: "Innovation Method"
      description: "The primary technical method, analytical approach, theoretical innovation, or application innovation used in the study, as explicitly positioned or described by the authors in comparison to prior work."
    - id: "experimental_scenario"
      label: "Application Scenario"
      description: "The specific task type or situational setup used in the experiment, and what problem the study addresses in that scenario."
    - id: "unresolved_questions"
      label: "Future Research Directions"
      description: "ALL problems the authors explicitly state were not solved in the current study but could be addressed in future work, together with the stated reasons and why the direction is necessary."
    - id: "evaluation_metrics"
      label: "Evaluation Metrics"
      description: "The dependent variables or criteria used to measure experimental outcomes or intervention effects."
    - id: "measurement_instruments"
      label: "Experimental Measurement Methods"
      description: "The core data collection methods used in the experiment, including software algorithms and hardware facilities."

# Recombination hard filters (displayed in UI, embedded in prompt)
filters:
  required_instruments:
    - "eye tracking"
    - "heart rate measurement"
    - "head movement tracking"
    - "hand movement tracking"
    - "validated self-report questionnaires"
  excluded_instruments:
    - "CAVE"
  excluded_populations:
    - "clinical populations"

# Chunking settings for long-paper processing
chunking:
  max_tokens: 12000         # token budget per chunk (estimated)
  overlap_tokens: 500       # overlap carried from previous chunk (in tokens)
  chars_per_token: 2.5      # estimation ratio (2.5 for English; 2.0 for CN/EN mixed)
  min_paragraph_tokens: 50  # paragraphs shorter than this merge with the next
